        160
      ],
      "id": "267bdd19-0373-4f85-8b29-a320d1d82e1d",
      "name": "Ollama Chat Model",
      "credentials": {
        "ollamaApi": {
          "id": "RwCDW0hKt5d5Ty39",
          "name": "Ollama account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rawOutput = $input.first().json.output || $input.first().json.text || '';\n\n// Strip markdown code fences if the model wrapped the output\nconst cleaned = rawOutput.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n\nlet questions;\ntry {\n  questions = JSON.parse(cleaned);\n} catch (e) {\n  // Fallback: extract the first [...] block\n  const match = cleaned.match(/\\[[\\s\\S]*\\]/);\n  if (match) {\n    questions = JSON.parse(match[0]);\n  } else {\n    throw new Error(`Could not parse questions from LLM output: ${rawOutput}`);\n  }\n}\n\nif (!Array.isArray(questions) || questions.length === 0) {\n  throw new Error(`Expected array of questions, got: ${JSON.stringify(questions)}`);\n}\n\nreturn questions.map(q => ({ json: { question: String(q) } }));"
      },
