    {
      "parameters": {
        "promptType": "define",
        "text": "=You are processing an Information Security Questionnaire (ISQ).\n\nExtract every question from the document text below. Return ONLY a valid JSON array of strings. Each string is one complete question as it appears in the document. Do not include section headers, field labels, or instructions — only the questions.\n\nExample format:\n[\"Do you maintain a formal information security policy?\", \"Is MFA enforced for all staff?\"]\n\nReturn only the JSON array. No explanation, no markdown.\n\nDocument text:\n{{ $json.text }}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        832,
        0
      ],
